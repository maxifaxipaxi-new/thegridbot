<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('partials/head') %>
    <title>The Grid - XP Verwaltung</title>
</head>
<body>
    <%- include('partials/sidebar', { currentPath: '/dashboard/xp' }) %>

    <div class="main-wrapper">
        <div class="top-bar">
            <h1 class="page-title">XP Verwaltung</h1>
            <p style="color: var(--text-muted); font-size: 14px;">Bearbeite die Erfahrungspunkte der User</p>
        </div>

        <main class="main-content">

            <% if (locals.errorMsg) { %>
                <div class="alert alert-error" style="margin-bottom: 24px; padding: 16px; background: rgba(239, 68, 68, 0.1); border: 1px solid var(--danger); border-radius: 12px; color: #f8fafc;">
                    <i class="fa-solid fa-triangle-exclamation" style="color: var(--danger); margin-right: 8px;"></i> <%= errorMsg %>
                </div>
            <% } %>

            <% if (locals.successMsg) { %>
                <div class="alert alert-success" style="margin-bottom: 24px; padding: 16px; background: rgba(16, 185, 129, 0.1); border: 1px solid var(--success); border-radius: 12px; color: #f8fafc;">
                    <i class="fa-solid fa-check-circle" style="color: var(--success); margin-right: 8px;"></i> <%= successMsg %>
                </div>
            <% } %>

            <div class="card" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title"><i class="fa-solid fa-circle-info" style="color: var(--accent-color); margin-right: 8px;"></i> Wie sammle ich XP?</h3>
                </div>
                <div class="card-body" style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                    <div>
                        <h4 style="color: var(--accent-color); margin-bottom: 12px; font-size: 14px; text-transform: uppercase;">Erfahrungspunkte (XP) sammeln</h4>
                        <ul style="list-style: none; font-size: 14px; color: var(--text-muted);">
                            <li style="margin-bottom: 8px;"><i class="fa-solid fa-check" style="color: var(--accent-color); margin-right: 8px;"></i> <b>Textnachrichten:</b> 5 - 10 XP pro Nachricht (1 Minute Cooldown).</li>
                            <li style="margin-bottom: 8px;"><i class="fa-solid fa-check" style="color: var(--accent-color); margin-right: 8px;"></i> <b>Voice-Chat:</b> 1 XP pro Minute (min. 2 Personen, max. 60 XP pro Tag).</li>
                            <li><i class="fa-solid fa-minus" style="color: var(--danger); margin-right: 8px;"></i> <b>Inaktivität:</b> Nach 3 Tagen Inaktivität werden täglich 10 XP abgezogen.</li>
                        </ul>
                    </div>
                    <div>
                        <h4 style="color: var(--accent-color); margin-bottom: 12px; font-size: 14px; text-transform: uppercase;">Level & Schwellenwerte</h4>
                        <ul style="list-style: none; font-size: 14px; color: var(--text-muted);">
                            <li style="margin-bottom: 8px;"><i class="fa-solid fa-star" style="color: var(--accent-color); margin-right: 8px;"></i> <b>Level 1:</b> 1.000 XP</li>
                            <li style="margin-bottom: 8px;"><i class="fa-solid fa-star" style="color: var(--accent-color); margin-right: 8px;"></i> <b>Level 2:</b> 3.000 XP</li>
                            <li style="margin-bottom: 8px;"><i class="fa-solid fa-star" style="color: var(--accent-color); margin-right: 8px;"></i> <b>Level 3:</b> 7.000 XP</li>
                            <li><i class="fa-solid fa-star" style="color: var(--accent-color); margin-right: 8px;"></i> <b>Level 4:</b> 15.000 XP</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">User XP bearbeiten</h3>
                </div>
                <div class="card-body">
                    <div style="overflow-x: auto;">
                        <table style="width: 100%; border-collapse: collapse; text-align: left;">
                            <thead>
                                <tr style="border-bottom: 1px solid var(--glass-border); color: var(--text-muted); font-size: 13px; text-transform: uppercase;">
                                    <th style="padding: 12px 16px;">User</th>
                                    <th style="padding: 12px 16px;">Aktuelle XP</th>
                                    <th style="padding: 12px 16px;">Level</th>
                                    <th style="padding: 12px 16px; text-align: right;">Aktion</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (usersList && usersList.length > 0) { %>
                                    <% usersList.forEach(u => { %>
                                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                            <td style="padding: 16px;">
                                                <div style="font-weight: 600;"><%= u.username %></div>
                                                <div style="font-size: 12px; color: var(--text-muted);"><%= u.id %></div>
                                            </td>
                                            <td style="padding: 16px;">
                                                <span style="background: rgba(249, 115, 22, 0.15); color: var(--accent-color); padding: 4px 8px; border-radius: 12px; font-weight: 600;">
                                                    <%= u.xp %> XP
                                                </span>
                                            </td>
                                            <td style="padding: 16px;">
                                                <% if (u.level > 0) { %>
                                                    <span style="background: rgba(255,255,255,0.1); padding: 4px 8px; border-radius: 8px; font-size: 13px;">Level <%= u.level %></span>
                                                <% } else { %>
                                                    <span style="color: var(--text-muted);">-</span>
                                                <% } %>
                                            </td>
                                            <td style="padding: 16px; text-align: right;">
                                                <form action="/dashboard/xp/edit" method="POST" style="display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
                                                    <input type="hidden" name="userId" value="<%= u.id %>">
                                                    <input type="number" name="newXp" value="<%= u.xp %>" style="width: 100px; padding: 8px; background: rgba(0,0,0,0.2); border: 1px solid var(--glass-border); border-radius: 8px; color: white; outline: none;">
                                                    <button type="submit" class="btn btn-primary" style="padding: 8px 16px;">Speichern</button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" style="text-align: center; padding: 40px; color: var(--text-muted);">
                                            Keine User-Daten gefunden.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
        <%- include('partials/footer') %>
    </div>
</body>
</html>
