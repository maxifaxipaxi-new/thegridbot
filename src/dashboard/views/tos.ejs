        p, ul { color: var(--text-muted); margin-bottom: 16px; }
        li { margin-bottom: 6px; }
        a { color: var(--accent-color); text-decoration: none; }
        a:hover { text-decoration: underline; }
        .back-btn { display: inline-block; margin-bottom: 30px; color: var(--text-main); background: var(--surface-color); padding: 8px 16px; border-radius: 8px; border: 1px solid var(--glass-border); }
