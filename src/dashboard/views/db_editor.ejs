<!DOCTYPE html>
<html lang="de">
<%- include('partials/head', { title: 'Datenbank Editor - the grid' }) %>
<body>
    <%- include('partials/sidebar', { currentPath: '/dashboard/db' }) %>

    <div class="main-wrapper">
        <div class="top-bar">
            <h1 class="page-title">Datenbank Editor</h1>
        </div>

        <main class="main-content">
            <p style="color: var(--text-muted); margin-bottom: 24px;">Bearbeite die rohe `db.json` direkt im Browser. <strong style="color: var(--danger);">Achtung: Falsches JSON kann den Bot zum Abstürzen bringen!</strong></p>

            <% if (locals.error) { %>
                <div class="alert alert-error"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
            <% } %>

            <div class="panel" style="border-top: 4px solid var(--danger);">
                <form action="/dashboard/db" method="POST">
                    <div style="margin-bottom: 16px;">
                        <textarea name="dbContent" id="dbContentArea" class="form-control" style="width: 100%; height: 500px; font-family: 'Courier New', Courier, monospace; background: rgba(0,0,0,0.4); color: #e2e8f0; resize: vertical;" spellcheck="false"><%= dbContent %></textarea>
                    </div>
                    <div style="display: flex; gap: 12px; justify-content: space-between; align-items: center;">
                        <div>
                            <a href="/dashboard/db/download" class="btn btn-outline" style="margin-right: 8px; display: inline-flex; align-items: center; gap: 8px;"><i class="fa-solid fa-download"></i> Herunterladen</a>
                            <label class="btn btn-outline" style="cursor: pointer; display: inline-flex; align-items: center; gap: 8px; margin: 0;">
                                <i class="fa-solid fa-upload"></i> Hochladen
                                <input type="file" accept=".json" style="display: none;" onchange="
                                    const file = this.files[0];
                                    if(file) {
                                        const reader = new FileReader();
                                        reader.onload = function(e) {
                                            document.getElementById('dbContentArea').value = e.target.result;
                                        };
                                        reader.readAsText(file);
                                    }
                                ">
                            </label>
                        </div>
                        <div style="display: flex; gap: 12px;">
                            <a href="/dashboard" class="btn btn-outline">Abbrechen</a>
                            <button type="submit" class="btn btn-danger"><i class="fa-solid fa-floppy-disk"></i> Speichern</button>
                        </div>
                    </div>
                </form>
            </div>
        </main>
        <%- include('partials/footer') %>
    </div>
</body>
</html>
