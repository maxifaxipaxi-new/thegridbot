<!DOCTYPE html>
<html lang="de">
<%- include('partials/head', { title: 'Ticket: ' + ticket.username + ' - the grid' }) %>
<body>
    <%- include('partials/sidebar', { currentPath: '/dashboard/tickets' }) %>

    <div class="main-wrapper">
        <div class="top-bar" style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <a href="/dashboard/tickets" class="btn btn-outline" style="margin-right: 12px; padding: 6px 12px;"><i class="fa-solid fa-arrow-left"></i> Zurück</a>
                <h1 class="page-title" style="display: inline-block;">Ticket: <%= ticket.username %></h1>
            </div>
            
            <div style="display: flex; gap: 8px;">
                <% if (ticket.status === 'open') { %>
                    <form action="/dashboard/tickets/<%= ticketId %>/close" method="POST" style="margin:0;">
                        <button type="submit" class="btn btn-outline" style="color: var(--danger); border-color: rgba(239,68,68,0.3);"><i class="fa-solid fa-lock"></i> Schließen</button>
                    </form>
                <% } else { %>
                    <form action="/dashboard/tickets/<%= ticketId %>/reopen" method="POST" style="margin:0;">
                        <button type="submit" class="btn btn-outline" style="color: #10b981; border-color: rgba(16, 185, 129, 0.3);"><i class="fa-solid fa-unlock"></i> Wieder öffnen</button>
                    </form>
                <% } %>
                <form action="/dashboard/tickets/<%= ticketId %>/delete" method="POST" style="margin:0;" onsubmit="return confirm('Sicher? Das Ticket wird unwiderruflich gelöscht.');">
                    <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Löschen</button>
                </form>
            </div>
        </div>

        <main class="main-content">
            <% if (!channelExists) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-triangle-exclamation"></i> 
                    Dieser Ticket-Kanal existiert nicht mehr in Discord. Er kann nur noch gelöscht werden.
                </div>
            <% } else { %>
                <div class="panel" style="display: flex; flex-direction: column; height: 60vh; padding: 0;">
                    
                    <!-- Chat History -->
                    <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px; background: rgba(0,0,0,0.2);">
                        <% if (messages.length === 0) { %>
                            <div style="color: var(--text-muted); text-align: center; margin-top: auto; margin-bottom: auto;">
                                Keine Nachrichten gefunden oder Fehler beim Laden.
                            </div>
                        <% } else { %>
                            <% messages.forEach(msg => { %>
                                <div style="display: flex; flex-direction: column; <%= msg.author.bot ? 'align-items: flex-end;' : 'align-items: flex-start;' %>">
                                    <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">
                                        <%= msg.author.tag %> • <%= new Date(msg.createdTimestamp).toLocaleString('de-DE') %>
                                    </div>
                                    <div style="
                                        max-width: 80%; 
                                        padding: 12px 16px; 
                                        border-radius: 12px;
                                        background: <%= msg.author.bot ? 'rgba(249, 115, 22, 0.2)' : 'rgba(255,255,255,0.05)' %>;
                                        border: 1px solid <%= msg.author.bot ? 'rgba(249, 115, 22, 0.3)' : 'var(--glass-border)' %>;
                                        color: #e2e8f0;
                                        word-wrap: break-word;
                                    ">
                                        <% if (msg.content) { %>
                                            <div style="white-space: pre-wrap;"><%= msg.content %></div>
                                        <% } %>
                                        <% if (msg.embeds && msg.embeds.length > 0) { %>
                                            <div style="font-style: italic; opacity: 0.7; font-size: 12px; margin-top: 4px;">[Embed Message]</div>
                                        <% } %>
                                    </div>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>

                    <!-- Chat Input -->
                    <% if (ticket.status === 'open') { %>
                        <div style="padding: 16px; border-top: 1px solid var(--glass-border); background: rgba(0,0,0,0.3);">
                            <form action="/dashboard/tickets/<%= ticketId %>/reply" method="POST" style="display: flex; gap: 12px; margin: 0;">
                                <input type="text" name="content" class="form-control" style="flex: 1;" placeholder="Schreibe eine Antwort als Bot..." required autocomplete="off">
                                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Senden</button>
                            </form>
                            <div style="font-size: 11px; color: var(--text-muted); margin-top: 8px;">
                                <i class="fa-solid fa-info-circle"></i> Die Nachricht wird als Embed mit dem Vermerk <strong>"Geantwortet von: <%= user.username %>"</strong> gesendet.
                            </div>
                        </div>
                    <% } else { %>
                        <div style="padding: 16px; border-top: 1px solid var(--glass-border); background: rgba(0,0,0,0.3); text-align: center; color: var(--danger);">
                            Dieses Ticket ist geschlossen. Du kannst keine Antworten mehr senden.
                        </div>
                    <% } %>

                </div>
            <% } %>
        </main>
        <%- include('partials/footer') %>
    </div>
    
    <script>
        // Auto-scroll chat to bottom
        const chatContainer = document.querySelector('.panel > div:first-child');
        if (chatContainer) {
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }
    </script>
</body>
</html>
